# =============================================
# Pathwise — Environment Variables
# Copy this to .env.local and fill in values
# =============================================

# Google AI (Gemini) — FREE, no credit card needed
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=AIza...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Mapbox (public key is safe to expose)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# Transport NSW Open Data
# Register at: https://opendata.transport.nsw.gov.au/
TRANSPORT_NSW_API_KEY=...

# Google Places API (for popular times + place details)
GOOGLE_PLACES_API_KEY=...

# Firecrawl (venue website scraping)
# Register at: https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
