# =============================================
# Pathwise — Environment Variables
# Copy this to .env.local and fill in values
# =============================================

# ── AI Provider (pick ONE — both are FREE) ────────────────────────────────
# Option 1: Groq — fastest, free, no credit card → https://console.groq.com
# Uses llama-3.3-70b-versatile. Takes priority if set.
GROQ_API_KEY=...

# Option 2: Google Gemini — free, 1500 req/day → https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Mapbox (public key is safe to expose)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# Transport NSW Open Data
# Register at: https://opendata.transport.nsw.gov.au/
TRANSPORT_NSW_API_KEY=...

# Google Places API (for popular times + place details)
GOOGLE_PLACES_API_KEY=...

# Firecrawl (venue website scraping)
# Register at: https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
